<?xml version="1.0" encoding="utf-8" ?>
<Theme baseTheme="Flex" title="NordicTouch" description="Scandinavian artisan art gallery theme" author="Smartstore" version="1.0">

    <Vars>
        <Var name="temp-topic" type="Color">#f6f4f2</Var>
        <!-- Common colors -->
        <Var name="gray-100" type="Color">#f6f4f2</Var>
        <Var name="gray-200" type="Color">#e8e4dd</Var>
        <Var name="gray-300" type="Color">#d6d0c8</Var>
        <Var name="gray-400" type="Color">#bdb5aa</Var>
        <Var name="gray-500" type="Color">#9e9488</Var>
        <Var name="gray-600" type="Color">#7d7268</Var>
        <Var name="gray-700" type="Color">#574e46</Var>
        <Var name="gray-800" type="Color">#3a3028</Var>
        <Var name="gray-900" type="Color">#211c16</Var>
        <Var name="white-200" type="Color">#fdfbf8</Var>

        <Var name="red" type="Color">#f44336</Var>
        <Var name="orange" type="Color">#ee9b00</Var>
        <Var name="yellow" type="Color">#ffeb3b</Var>
        <Var name="green" type="Color">#4caf50</Var>
        <Var name="blue" type="Color">#37a0e6</Var>
        <Var name="bluegrey" type="Color">#78909c</Var>
        <Var name="indigo" type="Color">#3f51b5</Var>
        <Var name="teal" type="Color">#009688</Var>
        <Var name="cyan" type="Color">#00bcd4</Var>
        <Var name="purple" type="Color">#9340d5</Var>
        <Var name="pink" type="Color">#ff5b77</Var>

        <!-- Artisan color palette -->
        <Var name="primary" type="Color">#2d2820</Var>
        <Var name="secondary" type="Color">#8a7f74</Var>
        <Var name="success" type="Color">#6b8c6e</Var>
        <Var name="warning" type="Color">#c4805a</Var>
        <Var name="danger" type="Color">#a85448</Var>
        <Var name="info" type="Color">#6b8cae</Var>
        <Var name="light" type="Color">lighten($gray-200, 2%)</Var>
        <Var name="dark" type="Color">#1a1510</Var>
        <Var name="brand-colors" type="String">primary,secondary,success,danger,warning,info,light,gray,dark</Var>

        <!-- Site & body: warm gallery cream (single tone for consistency) -->
        <Var name="body-bg" type="Color">#f6f4f2</Var>
        <Var name="site-bg" type="Color">#f6f4f2</Var>
        <Var name="body-color" type="Color">#1a1510</Var>
        <Var name="body-secondary-color" type="Color">#8a7f74</Var>
        <Var name="body-tertiary-color" type="Color">$gray-500</Var>
        <Var name="yiq-text-dark" type="Color">$gray-900</Var>
        <Var name="yiq-text-light" type="Color">#fff</Var>
        <Var name="text-muted" type="Color">$body-secondary-color</Var>
        <Var name="link-color" type="Color">#6b5a48</Var>

        <!-- Components: sharp, near-zero radii (Scandi minimal) -->
        <Var name="border-radius" type="String">0</Var>
        <Var name="border-radius-sm" type="String">0</Var>
        <Var name="border-radius-lg" type="String">0</Var>
        <Var name="border-radius-xl" type="String">0</Var>
        <Var name="border-radius-xxl" type="String">0</Var>

        <!-- Layout -->
        <Var name="boxed" type="Boolean">false</Var>

        <!-- Secondary Button -->
        <Var name="btn-secondary-bg" type="Color">#fff</Var>

        <!-- Top promo / announcement bar -->
        <Var name="nt-promo-bar-bg" type="Color">#f6f4f2</Var>
        <Var name="nt-promo-bar-color" type="Color">#1a1510</Var>
        <Var name="nt-promo-bar-border-color" type="Color">rgba(0,0,0,0.06)</Var>

        <!-- Header: transparent, minimal -->
        <Var name="header-bg" type="Color">#f6f4f2</Var>
        <Var name="header-color" type="Color">#2d2820</Var>
        <Var name="header-color-muted" type="Color">$body-secondary-color</Var>
        <Var name="inverse-menubar" type="Boolean">false</Var>
        <Var name="inverse-shopbar" type="Boolean">false</Var>
        <Var name="inverse-navbar" type="Boolean">false</Var>
        <Var name="menubar-bg" type="Color">transparent</Var>
        <Var name="shopbar-bg" type="Color">transparent</Var>
        <Var name="megamenu-bg" type="Color">#f7f3ee</Var>
        <Var name="menubar-color" type="Color">$body-color</Var>
        <Var name="shopbar-color" type="Color">$body-color</Var>
        <Var name="megamenu-color" type="Color">$body-color</Var>
        <Var name="menubar-inverse-color" type="Color">#fff</Var>
        <Var name="shopbar-inverse-color" type="Color">#fff</Var>
        <Var name="megamenu-inverse-color" type="Color">#fff</Var>
        <Var name="megamenu-line-height" type="String">1.8</Var>
        <Var name="megamenu-dropdown-bg" type="Color">#faf8f5</Var>
        <Var name="megamenu-heading-color" type="Color">#2d2820</Var>
        <Var name="megamenu-subitem-color" type="Color">#8a7f74</Var>
        <Var name="megamenu-text-color" type="Color">$body-color</Var>
        <Var name="megamenu-rotator-bg" type="Color">rgba(#fff, 0.92)</Var>

        <!-- Footer: warm off-white -->
        <Var name="inverse-footer" type="Boolean">false</Var>
        <Var name="footer-bg" type="Color">#f6f4f2</Var>
        <Var name="footer-color" type="Color">#1a1510</Var>
        <Var name="footer-color-muted" type="Color">#7d7268</Var>
        <Var name="footer-inverse-color" type="Color">#fff</Var>
        <Var name="footer-inverse-color-muted" type="Color">rgba(#fff, 0.5)</Var>
        <Var name="footer-social-bg" type="Color">transparent</Var>
        <Var name="footer-social-color" type="Color">darken($footer-color-muted, 10%)</Var>

        <!-- Common Font -->
        <Var name="google-font-1" type="String"></Var>
        <Var name="google-font-2" type="String"></Var>
        <Var name="google-font-3" type="String"></Var>

        <Var name="font-family-sans-serif" type="String">"Helvetica Neue", "Inter", -apple-system, system-ui, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif</Var>
        <Var name="font-family-monospace" type="String">Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace</Var>
        <Var name="font-size-base" type="String">0.875rem</Var>
        <Var name="font-size-lg" type="String">0.9375rem</Var>
        <Var name="font-size-sm" type="String">0.8125rem</Var>
        <Var name="font-size-xs" type="String">0.75rem</Var>

        <Var name="font-weight-light" type="String">300</Var>
        <Var name="font-weight-normal" type="String">400</Var>
        <Var name="font-weight-medium" type="String">500</Var>
        <Var name="font-weight-bold" type="String">600</Var>

        <!-- Headings -->
        <Var name="headings-font-family" type="String">inherit</Var>
        <Var name="headings-font-weight" type="String">$font-weight-normal</Var>
        <Var name="headings-line-height" type="String">1.25</Var>
        <Var name="headings-color" type="String">inherit</Var>
        <Var name="lead-font-weight" type="String">300</Var>
        <Var name="prose-headings-lg-font-weight" type="String">$font-weight-normal</Var>
        <Var name="prose-headings-sm-font-weight" type="String">$font-weight-medium</Var>

        <!-- h1-h6 — modest scale, restrained Scandi typography -->
        <Var name="h1-font-size" type="String">2rem</Var>
        <Var name="h2-font-size" type="String">1.5rem</Var>
        <Var name="h3-font-size" type="String">1.125rem</Var>
        <Var name="h4-font-size" type="String">1rem</Var>
        <Var name="h5-font-size" type="String">0.9375rem</Var>
        <Var name="h6-font-size" type="String">$font-size-base</Var>

        <!-- Misc typo -->
        <Var name="badge-content-shift" type="String">-1px</Var>

        <!-- Search: minimal, terracotta accent -->
        <Var name="searchbox-pill" type="Boolean">false</Var>
        <Var name="searchbox-shadow" type="Boolean">false</Var>
        <Var name="searchbox-outline-width" type="String">2px</Var>
        <Var name="searchbox-outline-color" type="Color">#c4805a</Var>
        <Var name="searchbox-bg-1" type="Color">#fff</Var>
        <Var name="searchbox-bg-2" type="Color">#fff</Var>
        <Var name="searchbox-bg-mobile" type="Color">$light</Var>
        <Var name="searchbox-color-1" type="Color">inherit</Var>
        <Var name="searchbox-color-2" type="Color">inherit</Var>
        <Var name="searchbox-border-1" type="Color">rgba(0,0,0, 0.12)</Var>
        <Var name="searchbox-border-2" type="Color">rgba(0,0,0, 0.12)</Var>
        <Var name="searchbox-border-mobile" type="Color">$light</Var>
        <Var name="searchbox-hit-tag-color" type="Color">darken($warning, 10%)</Var>

        <!-- Cards: soft, clean -->
        <Var name="card-border-radius" type="String">$border-radius</Var>
        <Var name="card-bg" type="Color">#fbf8f3</Var>
        <Var name="card-border-color" type="Color">rgba(0,0,0, .06)</Var>
        <Var name="card-cap-bg" type="Color">rgba(0,0,0, .03)</Var>

        <!-- Dropdowns -->
        <Var name="dropdown-bg" type="Color">#fff</Var>
        <Var name="dropdown-color" type="Color">$body-color</Var>
        <Var name="dropdown-border-color" type="Color">$gray-200</Var>
        <Var name="dropdown-border-radius" type="Color">$border-radius-lg</Var>
        <Var name="dropdown-divider-bg" type="Color">$gray-200</Var>
        <Var name="dropdown-box-shadow" type="String">$box-shadow-lg</Var>
        <Var name="dropdown-link-color" type="Color">$gray-700</Var>
        <Var name="dropdown-link-hover-color" type="Color">darken($dropdown-link-color, 5%)</Var>
        <Var name="dropdown-link-hover-bg" type="Color">mix($gray-100, $gray-200)</Var>

        <!-- Tables -->
        <Var name="table-bg" type="Color">transparent</Var>
        <Var name="table-accent-bg" type="Color">rgba(#000, .03)</Var>
        <Var name="table-hover-bg" type="Color">rgba(#000, .06)</Var>
        <Var name="table-active-bg" type="Color">$table-hover-bg</Var>
        <Var name="table-border-color" type="Color">$gray-300</Var>

        <!-- Shopbar badge -->
        <Var name="shopbar-label" type="Select#brand-colors">warning</Var>

        <!-- Misc -->
        <Var name="fa-use-pro" type="Boolean">false</Var>
        <Var name="fa-kit-id" type="String"></Var>
        <Var name="nav-tabs-active-link-color" type="Color">$gray-700</Var>
        <Var name="register-box-bg" type="Color">tint-color($gray-100, 40%)</Var>
        <Var name="art-active-bg-color" type="Color">#fff</Var>
        <Var name="art-active-border-color" type="Color">rgba(0,0,0, 0)</Var>

        <!-- Homepage: category cards -->
        <Var name="nt-category-card-bg" type="Color">#fbf8f3</Var>
        <Var name="nt-category-frame-bg" type="Color">#fbf8f3</Var>
        <Var name="nt-category-label-color" type="Color">#1a1510</Var>
        <Var name="nt-category-label-bg" type="Color">#fbf8f3</Var>

        <!-- Homepage: block & artlist -->
        <Var name="block-title-border-color" type="Color">rgba(0,0,0, 0.12)</Var>
        <Var name="art-btn-secondary-color" type="Color">#666</Var>
        <Var name="art-show-all-bg" type="Color">rgba(0,0,0, 0.06)</Var>

        <!-- Search & Facets -->
        <Var name="facet-group-header-color" type="Color">$body-color</Var>
        <Var name="facet-toggle-chevron-color" type="Color">$body-color</Var>
        <Var name="facet-selection-glyph-color" type="Color">#4d7a50</Var>
        <Var name="facet-group-border-color" type="Color">rgba(0,0,0, 0.12)</Var>
        <Var name="facet-control-border-color" type="Color">rgba(0,0,0, 0.2)</Var>
        <Var name="facet-control-checked-border-color" type="Color">rgba(0,0,0, 0.35)</Var>
        <Var name="facet-selection-badge-bg" type="Color">$info</Var>
        <Var name="facet-remove-link-color" type="Color">$danger</Var>
        <Var name="active-filter-badge-bg" type="Color">$light</Var>
        <Var name="active-filter-badge-color" type="Color">$body-color</Var>
        <Var name="active-filter-remove-bg" type="Color">$danger</Var>
        <Var name="active-filter-remove-color" type="Color">#ffffff</Var>
        <Var name="search-term-color" type="Color">#a85448</Var>
        <Var name="search-hitcount-color" type="Color">$body-secondary-color</Var>
        <Var name="instasearch-group-header-color" type="Color">$info</Var>
        <Var name="instasearch-divider-color" type="Color">rgba(0,0,0, 0.1)</Var>
        <Var name="instasearch-clear-color" type="Color">$gray-600</Var>

        <!-- Reviews -->
        <Var name="review-item-border-color" type="Color">rgba(0,0,0, 0.12)</Var>
        <Var name="write-review-bg" type="Color">$gray-100</Var>

        <!-- Gallery -->
        <Var name="gallery-thumb-border-color" type="Color">rgba(0,0,0, 0.12)</Var>
        <Var name="gallery-thumb-active-border-color" type="Color">rgba(0,0,0, 0.4)</Var>

        <!-- Offcanvas Menu -->
        <Var name="offcanvas-menu-bg" type="Color">#ffffff</Var>
        <Var name="offcanvas-menu-header-bg" type="Color">$gray-100</Var>
        <Var name="offcanvas-menu-border-color" type="Color">rgba(0,0,0, 0.1)</Var>
        <Var name="offcanvas-menu-selected-color" type="Color">$warning</Var>

        <!-- Misc UI -->
        <Var name="scroll-top-bg" type="Color">#ffffff</Var>
        <Var name="post-comment-border-color" type="Color">rgba(0,0,0, 0.12)</Var>

        <!-- Account & Identity -->
        <Var name="avatar-ring-outline-color" type="Color">#ffffff</Var>
        <Var name="login-box-bg" type="Color">#ffffff</Var>
        <Var name="pwd-policy-bg" type="Color">$light</Var>
        <Var name="pwd-rules-color" type="Color">$gray-600</Var>
        <Var name="payment-method-active-bg" type="Color">$gray-100</Var>
        <Var name="terms-consent-bg" type="Color">#f7f5f1</Var>
        <Var name="terms-consent-color" type="Color">$gray-700</Var>

        <!-- Product & checkout -->
        <Var name="product-price-color" type="Color">#2d2820</Var>
        <Var name="add-to-cart-btn-bg" type="Color">#2d2820</Var>
        <Var name="add-to-cart-btn-color" type="Color">#ffffff</Var>
        <Var name="product-stock-instock-color" type="Color">#5a7a5d</Var>
        <Var name="product-stock-outofstock-color" type="Color">#a85448</Var>
        <Var name="product-saving-percent-color" type="Color">#a85448</Var>
        <Var name="product-offer-countdown-color" type="Color">#c4805a</Var>
        <Var name="product-action-icon-color" type="Color">#9e9488</Var>
        <Var name="product-action-border-color" type="Color">rgba(0,0,0, 0.15)</Var>
        <Var name="product-tierprices-bg" type="Color">#fdfbf8</Var>
        <Var name="product-assoc-header-bg" type="Color">rgba(0,0,0, 0.05)</Var>
        <Var name="costep-progress-color" type="Color">#c4805a</Var>
        <Var name="costep-border" type="Color">#e8e4dd</Var>
        <Var name="costep-bg" type="Color">#fdfbf8</Var>
        <Var name="costep-color" type="Color">#bdb5aa</Var>
        <Var name="costep-label-color" type="Color">#2d2820</Var>
        <Var name="costep-active-bg" type="Color">#fdfbf8</Var>
        <Var name="costep-active-color" type="Color">#2d2820</Var>
        <Var name="costep-visited-color" type="Color">rgba(255,255,255, 0.85)</Var>
        <Var name="offcanvas-cart-body" type="Color">#fdfbf8</Var>
        <Var name="offcanvas-cart-footer" type="Color">#6b8c6e</Var>
        <Var name="offcanvas-cart-footer-color" type="Color">#ffffff</Var>
        <Var name="offcanvas-cart-item-border-color" type="Color">rgba(0,0,0, 0.15)</Var>
        <Var name="offcanvas-cart-empty-icon-color" type="Color">rgba(0,0,0, 0.15)</Var>
        <Var name="offcanvas-cart-throbber-bg" type="Color">#ffffff</Var>
        <Var name="cart-row-border-color" type="Color">#d6d0c8</Var>
        <Var name="cart-footer-divider-color" type="Color">rgba(0,0,0, 0.08)</Var>
        <Var name="product-detail-addtocart-box-bg" type="Color">#ede8e1</Var>
        <Var name="cart-footer-bg" type="Color">#ede8e1</Var>

        <!-- Buttons — universally dark/black with cream/white text (Louise-Roe minimal) -->
        <Var name="login-btn-bg" type="Color">#1a1510</Var>
        <Var name="login-btn-color" type="Color">#ffffff</Var>
        <Var name="register-btn-bg" type="Color">#1a1510</Var>
        <Var name="register-btn-color" type="Color">#ffffff</Var>
        <Var name="save-btn-bg" type="Color">#1a1510</Var>
        <Var name="save-btn-color" type="Color">#ffffff</Var>
        <Var name="checkout-next-btn-bg" type="Color">#1a1510</Var>
        <Var name="checkout-next-btn-color" type="Color">#ffffff</Var>
        <Var name="checkout-confirm-btn-bg" type="Color">#1a1510</Var>
        <Var name="checkout-confirm-btn-color" type="Color">#ffffff</Var>
        <Var name="offcanvas-viewcart-btn-bg" type="Color">#1a1510</Var>
        <Var name="offcanvas-viewcart-btn-color" type="Color">#ffffff</Var>
        <Var name="offcanvas-checkout-btn-bg" type="Color">#1a1510</Var>
        <Var name="offcanvas-checkout-btn-color" type="Color">#ffffff</Var>
        <Var name="newsletter-btn-bg" type="Color">#1a1510</Var>
        <Var name="newsletter-btn-color" type="Color">#ffffff</Var>
        <Var name="contact-btn-bg" type="Color">#1a1510</Var>
        <Var name="contact-btn-color" type="Color">#ffffff</Var>
        <Var name="pwd-recovery-btn-bg" type="Color">#1a1510</Var>
        <Var name="pwd-recovery-btn-color" type="Color">#ffffff</Var>
        <Var name="wishlist-btn-bg" type="Color">#1a1510</Var>
        <Var name="wishlist-btn-color" type="Color">#ffffff</Var>
        <Var name="coupon-btn-bg" type="Color">#1a1510</Var>
        <Var name="coupon-btn-color" type="Color">#ffffff</Var>
        <Var name="estimate-shipping-btn-bg" type="Color">#1a1510</Var>
        <Var name="estimate-shipping-btn-color" type="Color">#ffffff</Var>
    </Vars>

    <Selects>
        <Select id="brand-colors">
            <Option>primary</Option>
            <Option>secondary</Option>
            <Option>info</Option>
            <Option>success</Option>
            <Option>warning</Option>
            <Option>danger</Option>
            <Option>light</Option>
            <Option>dark</Option>
        </Select>
    </Selects>
</Theme>
